{
  "name": "text-computing",
  "version": "0.0.0",
  "description": "Workspace for deterministic text computing packages.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "lint": "npm run --workspaces --if-present lint",
    "schema:validate": "npm -w textfacts run schema:validate",
    "check:static": "npm run --workspaces --if-present check:static",
    "check:pack": "npm -w textfacts run check:pack",
    "check:publint": "npm -w textfacts run check:publint",
    "check:attw": "npm -w textfacts run check:attw",
    "check:jsr": "npm -w textfacts run check:jsr",
    "check:quality": "npm run check:static && npm run check:pack && npm run check:publint && npm run check:attw && npm run check:jsr",
    "test:all": "npm run --workspaces --if-present test",
    "test:workspaces": "npm run --workspaces --if-present test"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "ajv": "8.18.0",
    "esbuild": "0.27.3",
    "publint": "0.3.17",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
