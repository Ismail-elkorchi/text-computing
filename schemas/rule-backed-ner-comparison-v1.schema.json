{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/rule-backed-ner-comparison-v1.schema.json",
  "title": "Rule-backed NER comparison output v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scope", "capturedDate", "offsetUnits", "comparator", "slices"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scope": { "const": "rule-backed-ner" },
    "capturedDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "offsetUnits": { "const": "utf16-code-unit" },
    "comparator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "runtime", "command", "license", "artifactSurface"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "command": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "artifactSurface": { "type": "string", "minLength": 1 }
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/sliceComparison" }
    }
  },
  "definitions": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "startCU", "endCU", "text", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "startCU": { "type": "integer", "minimum": 0 },
        "endCU": { "type": "integer", "minimum": 0 },
        "text": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "mappedLabel": { "enum": ["PER", "ORG", "LOC"] }
      }
    },
    "sliceComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sliceId", "status", "entities"],
      "properties": {
        "sliceId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "status": { "enum": ["captured", "not-run"] },
        "reason": { "type": "string", "minLength": 1 },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/definitions/entity" }
        }
      }
    }
  }
}
