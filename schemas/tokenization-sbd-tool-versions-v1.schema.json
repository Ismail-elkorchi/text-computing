{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/tokenization-sbd-tool-versions-v1.schema.json",
  "title": "Tokenization and sentence boundary tool version manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scope", "primaryReferences", "packagesUnderTest", "diagnosticTools"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scope": { "const": "tokenization-sbd" },
    "primaryReferences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/reference" }
    },
    "packagesUnderTest": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/packageUnderTest" }
    },
    "diagnosticTools": {
      "type": "array",
      "items": { "$ref": "#/definitions/diagnosticTool" }
    }
  },
  "definitions": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "url", "artifactSurface"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "artifactSurface": { "type": "string", "minLength": 1 }
      }
    },
    "packageUnderTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "source", "artifactSurface"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "artifactSurface": { "type": "string", "minLength": 1 }
      }
    },
    "diagnosticTool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "artifactSurface"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "artifactSurface": { "type": "string", "minLength": 1 }
      }
    }
  }
}
