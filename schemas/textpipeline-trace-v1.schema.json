{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/textpipeline-trace-v1.schema.json",
  "title": "textpipeline trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "documentId", "finalRevision", "entries"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "documentId": { "type": "string", "minLength": 1 },
    "finalRevision": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "processorId",
          "version",
          "status",
          "emittedViews",
          "emittedLayers",
          "inputRevision",
          "outputRevision"
        ],
        "properties": {
          "processorId": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "status": { "enum": ["applied", "skipped"] },
          "emittedViews": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "emittedLayers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "severity"],
              "properties": {
                "code": { "type": "string", "minLength": 1 },
                "severity": { "enum": ["info", "warning", "error"] },
                "message": { "type": "string", "minLength": 1 }
              }
            }
          },
          "inputRevision": { "type": "string", "minLength": 1 },
          "outputRevision": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
