{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/textconformance-report-v1.schema.json",
  "title": "textconformance report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "schemaVersion", "reportId", "subject", "generatedAt", "summary", "checks"],
  "properties": {
    "schemaId": { "const": "urn:ismail-elkorchi:textconformance:report:v1" },
    "schemaVersion": { "const": 1 },
    "reportId": { "type": "string", "minLength": 1 },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "schemaId": { "type": "string", "minLength": 1 }
      }
    },
    "generatedAt": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass", "fail", "notRun"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "notRun": { "type": "integer", "minimum": 0 }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkId", "status"],
        "properties": {
          "checkId": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail", "not-run"] },
          "message": { "type": "string", "minLength": 1 },
          "evidenceRefs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
