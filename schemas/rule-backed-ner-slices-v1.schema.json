{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/rule-backed-ner-slices-v1.schema.json",
  "title": "Rule-backed NER readiness slices v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "expectedOutputStatus", "allowedFixturePolicy", "slices"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "expectedOutputStatus": { "enum": ["schema-defined", "recorded"] },
    "allowedFixturePolicy": { "type": "string", "minLength": 1 },
    "slices": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/definitions/slice" }
    }
  },
  "definitions": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text"],
      "properties": {
        "kind": { "const": "text" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "languageHint", "phenomena", "fixtureClass", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "languageHint": { "type": "string", "minLength": 1 },
        "phenomena": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "nested-span",
              "overlapping-span",
              "alias",
              "capitalization-ambiguity",
              "false-match"
            ]
          }
        },
        "fixtureClass": {
          "enum": ["repository-authored", "public-domain", "cc0-compatible"]
        },
        "source": { "$ref": "#/definitions/source" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
