{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/textpack-manifest-v1.schema.json",
  "title": "textpack manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "packageName",
    "version",
    "resources",
    "licenses",
    "provenance",
    "entrypoints",
    "tests"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packId": { "type": "string", "minLength": 1 },
    "packageName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/resource" }
    },
    "licenses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/license" }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/provenance" }
    },
    "entrypoints": { "$ref": "#/definitions/entrypoints" },
    "tests": { "$ref": "#/definitions/tests" },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "definitions": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resourceId",
        "lookupKey",
        "kind",
        "path",
        "overlayPrecedence",
        "licenseId",
        "provenanceId"
      ],
      "properties": {
        "resourceId": { "type": "string", "minLength": 1 },
        "lookupKey": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["lexicon", "stopwords", "gazetteer", "abbreviation-list"]
        },
        "path": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "profiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "overlayPrecedence": { "type": "integer", "minimum": 0 },
        "licenseId": { "type": "string", "minLength": 1 },
        "provenanceId": { "type": "string", "minLength": 1 }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "spdx"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "spdx": { "type": "string", "minLength": 1 },
        "attribution": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "origin"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "origin": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "retrievedFrom": { "type": "string", "minLength": 1 },
        "createdBy": { "type": "string", "minLength": 1 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "resourceRoot": { "type": "string", "minLength": 1 }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["smoke", "lookup", "overlay"],
      "properties": {
        "smoke": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "lookup": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "overlay": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
