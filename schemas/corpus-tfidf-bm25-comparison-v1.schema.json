{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus-tfidf-bm25-comparison-v1.schema.json",
  "title": "Corpus TF-IDF/BM25 comparison output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "comparator",
    "corpusId",
    "documentOrder",
    "outputs"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "corpusId": {
      "type": "string",
      "minLength": 1
    },
    "documentOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "comparator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "runtime"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "enum": [
            "python",
            "javascript",
            "jvm"
          ]
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
