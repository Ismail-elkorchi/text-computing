{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus-tfidf-bm25-expected-v1.schema.json",
  "title": "Corpus TF-IDF/BM25 expected output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "corpusId",
    "formulaSet",
    "documentOrder",
    "termOrder",
    "documents",
    "queries",
    "tolerance"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "corpusId": {
      "type": "string",
      "minLength": 1
    },
    "formulaSet": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "termOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tolerance": {
      "type": "number",
      "minimum": 0
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "length",
          "tf",
          "tfidf"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "length": {
            "type": "integer",
            "minimum": 0
          },
          "tf": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "term",
                "value"
              ],
              "properties": {
                "term": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                }
              }
            }
          },
          "tfidf": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "term",
                "value"
              ],
              "properties": {
                "term": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "bm25"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "bm25": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "docId",
                "score"
              ],
              "properties": {
                "docId": {
                  "type": "string",
                  "minLength": 1
                },
                "score": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
