{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ismail-elkorchi/text-computing/schemas/support-status-v1.schema.json",
  "title": "support status v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packages",
    "tasks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "scope",
          "evidence",
          "limitations"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "scaffold",
              "readiness-only",
              "slice-proven",
              "beta",
              "production-candidate"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "scope",
          "evidence",
          "limitations"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "scaffold",
              "readiness-only",
              "slice-proven",
              "beta",
              "production-candidate"
            ]
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
