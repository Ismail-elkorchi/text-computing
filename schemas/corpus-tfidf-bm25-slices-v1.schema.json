{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus-tfidf-bm25-slices-v1.schema.json",
  "title": "Corpus TF-IDF/BM25 readiness slices v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "expectedOutputStatus",
    "corpora"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "taskId": {
      "const": "nlp-corpus-tfidf-bm25"
    },
    "expectedOutputStatus": {
      "const": "recorded"
    },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "tokenPolicy",
          "phenomena",
          "documents",
          "queries"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "tokenPolicy": {
            "type": "string",
            "minLength": 1
          },
          "phenomena": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "repeated-term",
                "shared-term",
                "singleton-term",
                "empty-document",
                "missing-query-term",
                "stable-ordering"
              ]
            }
          },
          "documents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "tokens"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "tokens": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "metadata": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "queries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "tokens"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "tokens": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
